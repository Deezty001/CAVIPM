generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String        @id @default(cuid())
  name        String
  address     String        @default("")
  suburb      String        @default("")
  type        ProjectType   @default(RESIDENTIAL_SUBDIVISION)
  lotCount    Int?
  status      ProjectStatus @default(ACTIVE)
  logoUrl     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspaceId String?
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id])

  phases          Phase[]
  contacts        Contact[]
  meetings        Meeting[]
  personalActions PersonalAction[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships WorkspaceMember[]
  projects    Project[]
  actions     PersonalAction[]
  activities  ActivityEvent[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  initials  String
  avatarUrl String?
  timezone  String   @default("Australia/Sydney")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     WorkspaceMember[]
  assignedTasks   Task[]            @relation("InternalTaskAssignee")
  personalActions PersonalAction[]
  activities      ActivityEvent[]
  notifications   Notification[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectType {
  RESIDENTIAL_SUBDIVISION
  TOWNHOUSE_DEVELOPMENT
  MIXED_USE
  COMMERCIAL
  RENOVATION
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETE
}

model Phase {
  id        String  @id @default(cuid())
  name      String
  order     Int
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id               String           @id @default(cuid())
  name             String
  description      String?
  assigneeId       String?
  assigneeText     String?
  assignedUserId   String?
  startDate        DateTime?
  dueDate          DateTime?
  duration         Int?
  status           TaskStatus       @default(TODO)
  priority         Priority         @default(NORMAL)
  plannedDate      DateTime?
  estimateMinutes  Int?
  completedAt      DateTime?
  waitingOn        String?
  waitingSince     DateTime?
  followUpDate     DateTime?
  lastActivityAt   DateTime         @default(now())
  order            Int              @default(0)
  phaseId          String
  phase            Phase            @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  parentId         String?
  parent           Task?            @relation("Subtasks", fields: [parentId], references: [id])
  subtasks         Task[]           @relation("Subtasks")
  comments         Comment[]
  assignee         Contact?         @relation(fields: [assigneeId], references: [id])
  assignedUser     User?            @relation("InternalTaskAssignee", fields: [assignedUserId], references: [id])
  predecessorLinks TaskDependency[] @relation("DependencySuccessor")
  successorLinks   TaskDependency[] @relation("DependencyPredecessor")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
  WAITING
  CANCELLED
}

model TaskDependency {
  id            String         @id @default(cuid())
  predecessorId String
  successorId   String
  type          DependencyType @default(FINISH_TO_START)
  lagDays       Int            @default(0)
  isHard        Boolean        @default(false)
  createdAt     DateTime       @default(now())

  predecessor Task @relation("DependencyPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor   Task @relation("DependencySuccessor", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
  START_TO_FINISH
}

model PersonalAction {
  id              String     @id @default(cuid())
  title           String
  notes           String?
  status          TaskStatus @default(TODO)
  priority        Priority   @default(NORMAL)
  plannedDate     DateTime?
  dueDate         DateTime?
  estimateMinutes Int?
  completedAt     DateTime?
  waitingOn       String?
  waitingSince    DateTime?
  followUpDate    DateTime?
  isPrivate       Boolean    @default(true)
  ownerId         String
  workspaceId     String
  projectId       String?
  sourceTaskId    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([ownerId, plannedDate])
  @@index([ownerId, dueDate])
  @@index([workspaceId, status])
}

model ActivityEvent {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String?
  entityType  String
  entityId    String
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  type       String
  title      String
  body       String?
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  initials     String
  title        String?
  organisation String?
  email        String?
  phone        String?
  isInternal   Boolean  @default(false)
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        Task[]
  createdAt    DateTime @default(now())
}

model Meeting {
  id          String            @id @default(cuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        MeetingType       @default(PROGRESS_MEETING)
  date        DateTime
  endTime     DateTime?
  location    String?
  preparedBy  String?
  nextMeeting DateTime?
  attendees   MeetingAttendee[]
  agendaItems AgendaItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum MeetingType {
  WORKSHOP_AGENDA
  PROGRESS_MEETING
  CONSULTANT_BRIEFING
  SITE_MEETING
  OTHER
}

model MeetingAttendee {
  id           String  @id @default(cuid())
  name         String
  initials     String
  title        String?
  organisation String?
  meetingId    String
  meeting      Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model AgendaItem {
  id        String          @id @default(cuid())
  number    String
  title     String?
  order     Int             @default(0)
  meetingId String
  meeting   Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  subItems  AgendaSubItem[]
}

model AgendaSubItem {
  id           String     @id @default(cuid())
  number       String
  description  String
  action       String?
  owner        String?
  order        Int        @default(0)
  agendaItemId String
  agendaItem   AgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
}
