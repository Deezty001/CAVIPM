generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String        @id @default(cuid())
  name      String
  address   String        @default("")
  suburb    String        @default("")
  type      ProjectType   @default(RESIDENTIAL_SUBDIVISION)
  lotCount  Int?
  status    ProjectStatus @default(ACTIVE)
  logoUrl   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  phases   Phase[]
  contacts Contact[]
  meetings Meeting[]
}

enum ProjectType {
  RESIDENTIAL_SUBDIVISION
  TOWNHOUSE_DEVELOPMENT
  MIXED_USE
  COMMERCIAL
  RENOVATION
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETE
}

model Phase {
  id        String  @id @default(cuid())
  name      String
  order     Int
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id           String     @id @default(cuid())
  name         String
  description  String?
  assigneeId   String?
  assigneeText String?
  startDate    DateTime?
  dueDate      DateTime?
  duration     Int?
  status       TaskStatus @default(TODO)
  priority     Priority   @default(NORMAL)
  order        Int        @default(0)
  phaseId      String
  phase        Phase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       Task?      @relation("Subtasks", fields: [parentId], references: [id])
  subtasks     Task[]     @relation("Subtasks")
  comments     Comment[]
  assignee     Contact?   @relation(fields: [assigneeId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  initials     String
  title        String?
  organisation String?
  email        String?
  phone        String?
  isInternal   Boolean  @default(false)
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        Task[]
  createdAt    DateTime @default(now())
}

model Meeting {
  id          String           @id @default(cuid())
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        MeetingType      @default(PROGRESS_MEETING)
  date        DateTime
  endTime     DateTime?
  location    String?
  preparedBy  String?
  nextMeeting DateTime?
  attendees   MeetingAttendee[]
  agendaItems AgendaItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum MeetingType {
  WORKSHOP_AGENDA
  PROGRESS_MEETING
  CONSULTANT_BRIEFING
  SITE_MEETING
  OTHER
}

model MeetingAttendee {
  id           String  @id @default(cuid())
  name         String
  initials     String
  title        String?
  organisation String?
  meetingId    String
  meeting      Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model AgendaItem {
  id        String          @id @default(cuid())
  number    String
  title     String?
  order     Int             @default(0)
  meetingId String
  meeting   Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  subItems  AgendaSubItem[]
}

model AgendaSubItem {
  id           String     @id @default(cuid())
  number       String
  description  String
  action       String?
  owner        String?
  order        Int        @default(0)
  agendaItemId String
  agendaItem   AgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
}
